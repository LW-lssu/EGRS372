<launch>

  <!-- Launch TurtleBot3 navigation using your map -->
  <include file="$(find turtlebot3_navigation)/launch/turtlebot3_navigation.launch">
    <arg name="map_file" value="/home/egrs372/map.yaml" />
  </include>

  <!-- Home location parameters -->
  <param name="/home_location/x" value="0.0" />
  <param name="/home_location/y" value="0.0" />
  <param name="/home_location/theta" value="0.0" />

  <!-- Pick location parameters -->
  <param name="/pick_location/x" value="0.8" />
  <param name="/pick_location/y" value="-6.0" />
  <param name="/pick_location/theta" value="0.0" />

  <!-- Place location parameters -->
  <param name="/place_location/x" value="3.3" />
  <param name="/place_location/y" value="-7.6.0" />
  <param name="/place_location/theta" value="90.0" />

  <!-- Battery parameters -->
  <param name="/battery_low_level" value="10.0" />
  <param name="/battery_high_level" value="11.0" />

  <!-- Launch Lab 8 code -->
  <node pkg="lab7" type="lab7" name="lab7_launch" output="screen" />

</launch>



